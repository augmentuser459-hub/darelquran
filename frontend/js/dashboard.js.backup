/**
 * Dashboard Page - Main Logic
 */

// Global variables
let attendanceChart = null;
let revenueChart = null;

/**
 * Initialize Dashboard
 */
async function initDashboard() {
    try {
        // Load dashboard stats
        await loadDashboardStats();
        
        // Load today's sessions
        await loadTodaySessions();
        
        // Load recent payments
        await loadRecentPayments();
        
        // Initialize charts
        initCharts();
        
    } catch (error) {
        console.error('Error initializing dashboard:', error);
        showError('حدث خطأ في تحميل لوحة التحكم');
    }
}

/**
 * Load Dashboard Statistics
 */
async function loadDashboardStats() {
    try {
        const stats = await api.get(CONFIG.ACTIONS.dashboardStats);
        
        // Update stat cards with real data
        document.getElementById('totalStudents').textContent = stats.students?.active || 0;
        document.getElementById('totalTeachers').textContent = stats.teachers?.active || 0;
        document.getElementById('todaySessions').textContent = stats.sessions_today?.total || 0;
        
        // Calculate monthly revenue from payments
        const monthlyRevenue = stats.financial?.payments?.total_amount || 0;
        document.getElementById('monthlyRevenue').textContent = formatCurrency(monthlyRevenue);
        
        console.log('Dashboard stats loaded:', stats);
        
    } catch (error) {
        console.error('Error loading dashboard stats:', error);
        // Show default values on error
        document.getElementById('totalStudents').textContent = '0';
        document.getElementById('totalTeachers').textContent = '0';
        document.getElementById('todaySessions').textContent = '0';
        document.getElementById('monthlyRevenue').textContent = formatCurrency(0);
    }
}

/**
 * Load Today's Sessions
 */
async function loadTodaySessions() {
    try {
        const response = await api.get(CONFIG.ACTIONS.todaySessions);
        const sessions = Array.isArray(response) ? response : (response.results || []);
        const tbody = document.getElementById('todaySessionsBody');
        
        if (!sessions || sessions.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="4" style="text-align: center; padding: 2rem; color: var(--gray);">
                        <i class="fas fa-calendar-times" style="font-size: 3rem; margin-bottom: 1rem; display: block;"></i>
                        لا توجد حصص اليوم
                    </td>
                </tr>
            `;
            return;
        }
        
        tbody.innerHTML = sessions.map(session => `
            <tr>
                <td>${formatTime(session.session_time)}</td>
                <td>${session.student?.name || session.student_name || 'غير محدد'}</td>
                <td>${session.teacher?.name || session.teacher_name || 'غير محدد'}</td>
                <td>${getStatusBadge(session.status)}</td>
            </tr>
        `).join('');
        
    } catch (error) {
        console.error('Error loading today sessions:', error);
        document.getElementById('todaySessionsBody').innerHTML = `
            <tr>
                <td colspan="4" style="text-align: center; padding: 2rem; color: var(--danger-color);">
                    <i class="fas fa-exclamation-triangle"></i>
                    حدث خطأ في تحميل الحصص
                </td>
            </tr>
        `;
    }
}

/**
 * Load Recent Payments
 */
async function loadRecentPayments() {
    try {
        const response = await api.get(CONFIG.ACTIONS.recentPayments);
        const payments = Array.isArray(response) ? response : (response.results || []);
        const tbody = document.getElementById('recentPaymentsBody');
        
        if (!payments || payments.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" style="text-align: center; padding: 2rem; color: var(--gray);">
                        <i class="fas fa-money-bill-wave" style="font-size: 3rem; margin-bottom: 1rem; display: block;"></i>
                        لا توجد مدفوعات حديثة
                    </td>
                </tr>
            `;
            return;
        }
        
        tbody.innerHTML = payments.map(payment => `
            <tr>
                <td>${formatDate(payment.payment_date)}</td>
                <td>${payment.student?.name || payment.student_name || 'غير محدد'}</td>
                <td>${formatCurrency(payment.amount)}</td>
                <td>${payment.payment_method || 'غير محدد'}</td>
                <td><span class="badge badge-success">مكتمل</span></td>
            </tr>
        `).join('');
        
    } catch (error) {
        console.error('Error loading recent payments:', error);
        document.getElementById('recentPaymentsBody').innerHTML = `
            <tr>
                <td colspan="5" style="text-align: center; padding: 2rem; color: var(--danger-color);">
                    <i class="fas fa-exclamation-triangle"></i>
                    حدث خطأ في تحميل المدفوعات
                </td>
            </tr>
        `;
    }
}

